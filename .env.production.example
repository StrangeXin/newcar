# Database
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/newcar
POSTGRES_DB=newcar
POSTGRES_USER=REPLACE_ME
POSTGRES_PASSWORD=REPLACE_ME

# Redis
REDIS_URL=redis://:PASSWORD@redis:6379
REDIS_PASSWORD=REPLACE_ME

# Authentication
JWT_SECRET=REPLACE_ME_64_CHARS_OR_MORE
OTP_SECRET=REPLACE_ME_32_CHARS_OR_MORE

# WeChat
WECHAT_APP_ID=REPLACE_ME
WECHAT_APP_SECRET=REPLACE_ME
WECHAT_TEMPLATE_PRICE_DROP=REPLACE_ME
WECHAT_TEMPLATE_NEW_REVIEW=REPLACE_ME
WECHAT_TEMPLATE_POLICY_UPDATE=REPLACE_ME
WECHAT_TEMPLATE_OTA_RECALL=REPLACE_ME

# AI Service
AI_API_KEY=REPLACE_ME
AI_MODEL=MiniMax-M2.7
AI_BASE_URL=https://api.minimaxi.com/anthropic

# Weaviate
WEAVIATE_HOST=http://weaviate:8080
WEAVIATE_API_KEY=REPLACE_ME

# Application
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_CDN_HOST=cdn.example.com
